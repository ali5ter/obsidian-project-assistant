#!/usr/bin/env bash
# @file migrate
# @brief Migrate from bash-installer-based v2.x to plugin framework v3.x
# @author Alister Lewis-Bowen <alister@lewis-bowen.org>
# @version 3.2.1
# @usage ./migrate
# @dependencies bash 4+
# @exit 0 Success (migration complete or nothing to migrate)

set -euo pipefail

command -v pfb &>/dev/null || pfb() {
    local cmd="$1"; shift || true
    case "$cmd" in
        heading)  printf '\n%s\n' "${2:+$2 }$1" ;;
        success)  printf '  ✓ %s\n' "$1" ;;
        warn)     printf '  ! %s\n' "$1" ;;
        info)     printf '  → %s\n' "$1" ;;
        err)      printf '  ✗ %s\n' "$1" ;;
    esac
}

OLD_SKILL="$HOME/.claude/skills/obsidian-project-documentation"
OLD_AGENT="$HOME/.claude/agents/obsidian-project-documentation-manager.md"
OLD_CONFIG="$OLD_SKILL/config.json"
NEW_CONFIG="$HOME/.claude/obsidian-project-assistant-config.json"

if [[ ! -d "$OLD_SKILL" ]]; then
    pfb info "No old installation found. Nothing to migrate."
    exit 0
fi

pfb heading "Migrating v2.x installation" "🔄"
pfb info "Found old v2.x installation at $OLD_SKILL"

if [[ -f "$OLD_CONFIG" ]]; then
    cp "$OLD_CONFIG" "$NEW_CONFIG"
    pfb success "Config preserved → $NEW_CONFIG"
else
    pfb warn "No config found at $OLD_CONFIG — you will be prompted for your vault path on first use."
fi

rm -rf "$OLD_SKILL"
pfb success "Removed old skill directory: $OLD_SKILL"

if [[ -f "$OLD_AGENT" ]]; then
    rm -f "$OLD_AGENT"
    pfb success "Removed old agent file: $OLD_AGENT"
fi

pfb heading "Migration complete" "✅"
pfb info "/plugin marketplace add ali5ter/claude-plugins"
pfb info "/plugin install obsidian-project-documentation@ali5ter"

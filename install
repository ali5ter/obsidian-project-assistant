#!/usr/bin/env bash
# @file install
# @brief DEPRECATED - Use the Claude Code plugin system instead.
# @author Alister Lewis-Bowen <alister@lewis-bowen.org>
# @version 3.2.1
# @usage ./install
# @dependencies bash 4+
# @exit 0 Always exits 0 (prints redirect message)

cat <<'EOF'
The bash installer has been replaced by the Claude Code plugin system.

New install (run inside Claude Code):

  /plugin marketplace add ali5ter/claude-plugins
  /plugin install obsidian-project-documentation@ali5ter

The first time you trigger the skill it will ask for your vault path —
no separate setup step needed.

Upgrading from v2.x? Run the migration script first:

  ./migrate

Then install via the plugin commands above.
EOF
